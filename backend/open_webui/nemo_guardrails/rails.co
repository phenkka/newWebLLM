define bot refuse to respond
  "Это сообщение нарушает политику безопасности. Задай другой вопрос. / This message violates our safety policy. Please ask something else."


define flow self_check_input
  $allowed = execute self_check_input
  if not $allowed
    bot refuse to respond
    stop


define flow topic_control_check
  if "как взорвать" in $user_message
    bot say "Запрос о взрывчатых веществах или терроризме недопустим. / Requests about explosives or terrorism are not allowed."
    stop

  if "взовать" in $user_message
    bot say "Запрос о взрывчатых веществах или терроризме недопустим. / Requests about explosives or terrorism are not allowed."
    stop

  if "взрывчатку" in $user_message and "сделать" in $user_message
