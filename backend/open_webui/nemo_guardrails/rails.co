define flow output_injection_check
  if ":(){ :|:& };:" in $bot_response
    bot say "Ответ заблокирован — обнаружена инъекция кода. / Output blocked — code injection detected."
    stop

  if "rm -rf /" in $bot_response
    bot say "Ответ заблокирован — обнаружена опасная команда. / Output blocked — dangerous shell command detected."
    stop

  if "dd if=/dev/zero" in $bot_response
    bot say "Output blocked — dangerous shell command detected."
    stop

  if "<script>" in $bot_response
    bot say "Output blocked — XSS injection detected."
    stop

  if "eval(base64_decode" in $bot_response
    bot say "Output blocked — code injection detected."
    stop

  if "exec(compile" in $bot_response
    bot say "Output blocked — code injection detected."
    stop

  if "__import__('os').system" in $bot_response
    bot say "Output blocked — code injection detected."
    stop
